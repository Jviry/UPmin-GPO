// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  admin_id      Int            @id @default(autoincrement())
  email         String         @unique
  name          String
  password      String
  role          String
  announcements Announcement[]
  scholarships  Scholarship[]
}

model Announcement {
  announcement_id     Int      @id @default(autoincrement())
  title               String
  image_url           String?
  content_description String
  attached_link       String?
  admin_id            Int
  admin               Admin    @relation(fields: [admin_id], references: [admin_id])
  date_posted         DateTime @default(now())
}

model Scholarship {
  scholarship_id           Int     @id @default(autoincrement())
  name                     String
  description              String
  covered_programs         String
  application_instructions String
  application_url          String
  recommendation_url       String?
  contact_info             String  @unique

  admin_id Int
  admin    Admin @relation(fields: [admin_id], references: [admin_id])
}

model Office {
  office_id     Int    @id @default(autoincrement())
  logo          String
  mission       String
  vision        String
  core_values   String
  history       String
  phone         String
  email         String
  org_chart_url String

  featuredPhotos FeaturedPhoto[]
}

model FeaturedPhoto {
  featured_photo_id Int    @id @default(autoincrement())
  url               String

  office_id Int
  office    Office @relation(fields: [office_id], references: [office_id])
}

model Testimony {
  testimony_id             Int    @id @default(autoincrement())
  alumnus_name             String
  testimony_description    String
  alumnus_graduate_program String
}

model College {
  college_id   Int    @id @default(autoincrement())
  name         String
  current_dean String

  departments Department[]
}

model Department {
  department_id Int    @id @default(autoincrement())
  name          String
  head          String
  contact_info  String @unique

  college_id Int
  college    College @relation(fields: [college_id], references: [college_id])

  courses  Course[]
  programs Program[]
  faculty  Faculty[]
}

model Faculty {
  faculty_id           Int    @id @default(autoincrement())
  name                 String
  email                String @unique
  photo                String
  position             String
  university_graduated String

  department_id Int
  department    Department @relation(fields: [department_id], references: [department_id])
}

model Program {
  program_id               Int    @id @default(autoincrement())
  type                     String // e.g., "Diploma Program", "Graduate Program"
  name                     String
  description              String
  history                  String
  qualifications           String
  application_instructions String
  application_url          String

  department_id Int
  department    Department @relation(fields: [department_id], references: [department_id])

  program_courses ProgramCourse[]
  study_plans     StudyPlan[]
}

model StudyPlan {
  study_plan_id Int @id @default(autoincrement())
  years         Int

  program_courses ProgramCourse[]
  elective_pool   ElectivePool[]
  program_id      Int
  program         Program         @relation(fields: [program_id], references: [program_id])
}

model ElectivePool {
  elective_pool_id Int @id @default(autoincrement())

  study_plan_id Int
  study_plan    StudyPlan @relation(fields: [study_plan_id], references: [study_plan_id])
  course_id     Int
  course        Course    @relation(fields: [course_id], references: [course_id])
}

model ProgramCourse {
  program_course_id Int        @id @default(autoincrement())
  year              Int?
  semester          Int?
  is_elective_slot  Boolean    @default(false)
  is_placed         Boolean    @default(false) // false = still in pool, true = placed in study plan
  study_plan_id     Int?
  course_id         Int?
  program_id        Int
  program           Program    @relation(fields: [program_id], references: [program_id])
  study_plan        StudyPlan? @relation(fields: [study_plan_id], references: [study_plan_id])
  course            Course?    @relation(fields: [course_id], references: [course_id])
}

model Course {
  course_id Int    @id @default(autoincrement())
  name      String
  code      String
  type      String
  units     Int

  department_id Int?
  department    Department? @relation(fields: [department_id], references: [department_id])

  elective_pool   ElectivePool[]
  program_courses ProgramCourse[]
}
